{"ast":null,"code":"import{useInventory}from'../../../contexts/inventory/InventoryContext';export class InventoryMessageEvent{constructor(callBack){this.connection=void 0;this.parser=void 0;this.parserClass=void 0;this.callBack=void 0;this.callBack=callBack;this.parserClass=null;}parse(wrapper){const items=[];const itemCount=wrapper.readInt();for(let i=0;i<itemCount;i++){const item={id:wrapper.readInt(),itemId:wrapper.readInt(),userId:wrapper.readInt(),slot:wrapper.readInt(),quantity:wrapper.readInt(),durability:wrapper.readInt(),name:wrapper.readString(),icon:wrapper.readString(),type:wrapper.readString()};items.push(item);}const{setItems}=useInventory();setItems(items);if(this.callBack)this.callBack(this);}dispose(){this.connection=null;this.parser=null;this.parserClass=null;this.callBack=null;}}","map":null,"metadata":{},"sourceType":"module"}