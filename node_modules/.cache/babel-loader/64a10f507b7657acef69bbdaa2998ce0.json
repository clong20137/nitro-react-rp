{"ast":null,"code":"import{useEffect,useState}from\"react\";import{UserStatsMessageEvent}from\"../../api/messages/incoming/UserStatsMessageEvent\";import{GetCommunication}from\"../../api/nitro/GetCommunication\";import\"./StatsBar.scss\";import{jsx as _jsx}from\"react/jsx-runtime\";import{jsxs as _jsxs}from\"react/jsx-runtime\";export const StatsBar=()=>{const[health,setHealth]=useState(100);const[energy,setEnergy]=useState(100);const[hunger,setHunger]=useState(100);useEffect(()=>{const connection=GetCommunication().connection;if(!connection)return;const onStats=event=>{const parser=event.getParser();setHealth(parser.health);setEnergy(parser.energy);setHunger(parser.hunger);};connection.addMessageEvent(new UserStatsMessageEvent(onStats));return()=>connection.removeMessageEvent(new UserStatsMessageEvent(onStats));},[]);const barWidth=v=>`${v}%`;return/*#__PURE__*/_jsxs(\"div\",{className:\"stats-bar-container\",children:[/*#__PURE__*/_jsxs(\"div\",{className:\"stat\",children:[/*#__PURE__*/_jsx(\"div\",{className:\"icon heart\"}),/*#__PURE__*/_jsx(\"div\",{className:\"bar\",children:/*#__PURE__*/_jsx(\"div\",{className:\"fill health\",style:{width:'${health}%'}})})]}),/*#__PURE__*/_jsxs(\"div\",{className:\"stat\",children:[/*#__PURE__*/_jsx(\"div\",{className:\"icon bolt\"}),/*#__PURE__*/_jsx(\"div\",{className:\"bar\",children:/*#__PURE__*/_jsx(\"div\",{className:\"fill energy\",style:{width:barWidth(energy)}})})]}),/*#__PURE__*/_jsxs(\"div\",{className:\"stat\",children:[/*#__PURE__*/_jsx(\"div\",{className:\"icon apple\"}),/*#__PURE__*/_jsx(\"div\",{className:\"bar\",children:/*#__PURE__*/_jsx(\"div\",{className:\"fill hunger\",style:{width:barWidth(hunger)}})})]})]});};","map":null,"metadata":{},"sourceType":"module"}