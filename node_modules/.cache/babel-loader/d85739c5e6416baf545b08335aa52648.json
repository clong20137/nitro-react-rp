{"ast":null,"code":"export class UserStatsParser{constructor(){this._stats={health:0,maxHealth:100,energy:0,maxEnergy:100,hunger:0,maxHunger:100,aggression:0};}flush(){this._stats={health:0,maxHealth:100,energy:0,maxEnergy:100,hunger:0,maxHunger:100,aggression:0};return true;}parse(wrapper){this._stats.health=wrapper.readInt();this._stats.maxHealth=wrapper.readInt();this._stats.energy=wrapper.readInt();this._stats.maxEnergy=wrapper.readInt();this._stats.hunger=wrapper.readInt();this._stats.maxHunger=wrapper.readInt();this._stats.aggression=wrapper.readInt();return true;}get stats(){return this._stats;}}","map":null,"metadata":{},"sourceType":"module"}