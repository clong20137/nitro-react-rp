{"ast":null,"code":"export class UserStatsParser{constructor(){this._stats={health:0,energy:0,aggression:0,hunger:0};}flush(){this._stats={health:0,energy:0,aggression:0,hunger:0};return true;}parse(wrapper){this._stats.health=wrapper.readInt();this._stats.energy=wrapper.readInt();this._stats.aggression=wrapper.readInt();this._stats.hunger=wrapper.readInt();return true;}get stats(){return this._stats;}}","map":null,"metadata":{},"sourceType":"module"}