{"ast":null,"code":"import{useEffect,useState}from\"react\";import\"./ZeusStatsBar.scss\";import{jsx as _jsx}from\"react/jsx-runtime\";import{jsxs as _jsxs}from\"react/jsx-runtime\";const ZeusStatsBar=()=>{const[stats,setStats]=useState({health:0,maxHealth:250});useEffect(()=>{const handleUpdate=event=>{const{health,maxHealth}=event.detail;setStats({health,maxHealth});};window.addEventListener(\"zeus_stats_update\",handleUpdate);return()=>{window.removeEventListener(\"zeus_stats_update\",handleUpdate);};},[]);const percent=Math.round(stats.health/stats.maxHealth*100);return/*#__PURE__*/_jsxs(\"div\",{className:\"zeus-health-bar-container\",children:[/*#__PURE__*/_jsx(\"div\",{className:\"zeus-health-bar-fill\",style:{width:`${percent}%`}}),/*#__PURE__*/_jsxs(\"div\",{className:\"zeus-health-bar-text\",children:[\"ZEUS HEALTH: \",stats.health,\" / \",stats.maxHealth]})]});};export default ZeusStatsBar;","map":null,"metadata":{},"sourceType":"module"}