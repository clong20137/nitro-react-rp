{"ast":null,"code":"export class GangStatusParser{constructor(){this._data=this.createEmptyData();}createEmptyData(){return{inGang:false,gangName:'',gangRank:0,primaryColor:'',secondaryColor:'',xp:0,maxXp:0,kills:0,deaths:0,robberies:0,pickpockets:0,totalDamage:0,turfsControlled:0};}flush(){this._data=this.createEmptyData();return true;}parse(wrapper){this._data.inGang=wrapper.readBoolean();this._data.gangName=wrapper.readString();this._data.gangRank=wrapper.readInt();this._data.primaryColor=wrapper.readString();this._data.secondaryColor=wrapper.readString();this._data.xp=wrapper.readInt();this._data.maxXp=wrapper.readInt();this._data.kills=wrapper.readInt();this._data.deaths=wrapper.readInt();this._data.robberies=wrapper.readInt();this._data.pickpockets=wrapper.readInt();this._data.totalDamage=wrapper.readInt();this._data.turfsControlled=wrapper.readInt();window.dispatchEvent(new CustomEvent('gang_status_result',{detail:this._data}));return true;}get data(){return this._data;}}","map":null,"metadata":{},"sourceType":"module"}